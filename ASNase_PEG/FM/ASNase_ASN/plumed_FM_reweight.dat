# RESTART
MOLINFO STRUCTURE=./ASNase_ASN_npt.pdb
WHOLEMOLECULES ENTITY0=5,26,38,52,71,85,104,123,133,147,154,161,175,194,204,211,218,225,237,248,258,272,294,305,319,340,354,364,371,393,409,416,432,447,461,480,496,510,520,538,550,567,586,608,620,639,649,663,679,701,708,723,740,756,772,786,805,812,823,840,852,869,883,895,907,923,947,966,980,999,1009,1031,1053,1072,1086,1100,1112,1122,1134,1156,1170,1182,1189,1209,1225,1244,1258,1275,1282,1296,1308,1322,1339,1354,1369,1383,1393,1414,1434,1453,1466,1485,1499,1515,1537,1547,1559,1583,1595,1611,1627,1644,1660,1667,1677,1694,1720,1732,1743,1757,1768,1785,1796,1806,1818,1827,1839,1859,1873,1892,1913,1927,1937,1953,1969,1983,1993,2003,2015,2037,2047,2058,2068,2082,2106,2113,2129,2148,2164,2180,2197,2211,2223,2237,2253,2272,2284,2291,2315,2327,2343,2357,2379,2393,2407,2421,2435,2447,2463,2473,2487,2507,2529,2540,2556,2570,2591,2600,2612,2631,2638,2659,2678,2695,2709,2716,2738,2757,2769,2790,2807,2831,2847,2859,2869,2893,2915,2932,2946,2957,2969,2985,2997,3017,3029,3045,3056,3078,3097,3111,3126,3147,3159,3181,3197,3204,3223,3239,3260,3274,3295,3305,3319,3329,3340,3352,3373,3385,3395,3417,3427,3446,3462,3474,3484,3491,3512,3524,3531,3550,3566,3577,3587,3594,3610,3617,3631,3638,3652,3671,3692,3714,3728,3744,3764,3776,3790,3809,3819,3833,3843,3853,3875,3889,3896,3910,3920,3936,3952,3976,3987,3998,4022,4040,4052,4066,4073,4083,4097,4111,4128,4140,4150,4165,4181,4193,4205,4215,4237,4258,4265,4285,4301,4311,4322,4329,4343,4362,4378,4390,4407,4429,4439,4463,4479,4498,4517,4534,4553,4563,4582,4596,4613,4627,4649,4663,4675,4692,4709,4728,4745,4762,4781,4801,4815,4832,4852,4856,4857,4858,4859,4860,4862,4865,4866

lig: COM ATOMS=4852,4856,4857,4858,4859,4860,4862,4865,4866
# CV1 - distance between 12THR-OG1 and LASN-CG
d1: DISTANCE ATOMS=165,4862
# define the funnel potential region
fps: FUNNEL_PS LIGAND=lig REFERENCE=ASNase_alignment.pdb ANCHOR=869 POINTS=4.289,5.27,6.453,5.124,4.761,6.665
# calculate RMSD for constraint
#rmsd: RMSD REFERENCE=ASNase_alignment.pdb TYPE=OPTIMAL

# FUNNEL ARG=fps.lp,fps.ld ZCC=2.4 ALPHA=0.55 RCYL=0.1 MINS=-0.5 MAXS=4.4 KAPPA=35100 NBINS=500 NBINZ=500 FILE=../BIAS LABEL=funnel

# Metadynamics 
METAD ARG=d1 SIGMA=0.05 HEIGHT=0 PACE=1000000000 TEMP=310 BIASFACTOR=20 GRID_MIN=0 GRID_MAX=5 FILE=./HILLS LABEL=metad RESTART=YES

# reweighting
# as: REWEIGHT_BIAS ARG=metad.bias
as: REWEIGHT_METAD ARG=metad.bias TEMP=310
# # using the weights obtained from the metadynamics bias potentials
fps_hh: HISTOGRAM ARG=fps.lp,fps.ld STRIDE=10 GRID_MIN=-0.5,0 GRID_MAX=4.4,2 GRID_BIN=500,200 BANDWIDTH=0.05,0.05 LOGWEIGHTS=as 

fps_ff: CONVERT_TO_FES GRID=fps_hh TEMP=310 MINTOZERO
# Print out the free energies F(s) to file once the entire trajectory is processed
DUMPGRID GRID=fps_ff FILE=ffphi.dat 

PRINT STRIDE=1 ARG=fps.lp,fps.ld,metad.bias FILE=COLVAR_REWEIGHT

