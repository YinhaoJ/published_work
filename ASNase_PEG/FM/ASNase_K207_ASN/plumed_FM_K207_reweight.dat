# RESTART
# parameter
MOLINFO STRUCTURE=./ASNase_K207_ASN_NPT.pdb
WHOLEMOLECULES ENTITY0=5,26,38,52,71,85,104,123,133,147,154,161,175,194,204,211,218,225,237,248,258,272,294,305,319,340,354,364,371,393,409,416,432,447,461,480,496,510,520,538,550,567,586,608,620,639,649,663,679,701,708,723,740,756,772,786,805,812,823,840,852,869,883,895,907,923,947,966,980,999,1009,1031,1053,1072,1086,1100,1112,1122,1134,1156,1170,1182,1189,1209,1225,1244,1258,1275,1282,1296,1308,1322,1339,1354,1369,1383,1393,1414,1434,1453,1466,1485,1499,1515,1537,1547,1559,1583,1595,1611,1627,1644,1660,1667,1677,1694,1720,1732,1743,1757,1768,1785,1796,1806,1818,1827,1839,1859,1873,1892,1913,1927,1937,1953,1969,1983,1993,2003,2015,2037,2047,2058,2068,2082,2106,2113,2129,2148,2164,2180,2197,2211,2223,2237,2253,2272,2284,2291,2315,2327,2343,2357,2379,2393,2407,2421,2435,2447,2463,2473,2487,2507,2529,2540,2556,2570,2591,2600,2612,2631,2638,2659,2678,2695,2709,2716,2738,2757,2769,2790,2807,2831,2847,2859,2869,2893,2915,2932,2946,2957,2969,2985,2997,3017,3029,3045,3056,3873,3892,3906,3921,3942,3954,3976,3992,3999,4018,4034,4055,4069,4090,4100,4114,4124,4135,4147,4168,4180,4190,4212,4222,4241,4257,4269,4279,4286,4307,4319,4326,4345,4361,4372,4382,4389,4405,4412,4426,4433,4447,4466,4487,4509,4523,4539,4559,4571,4585,4604,4614,4628,4638,4648,4670,4684,4691,4705,4715,4731,4747,4771,4782,4793,4817,4835,4847,4861,4868,4878,4892,4906,4923,4935,4945,4960,4976,4988,5000,5010,5032,5053,5060,5080,5096,5106,5117,5124,5138,5157,5173,5185,5202,5224,5234,5258,5274,5293,5312,5329,5348,5358,5377,5391,5408,5422,5444,5458,5470,5487,5504,5523,5540,5557,5576,5596,5610,5627

r1: GYRATION ATOMS=3073,3082,3089,3096,3103,3110,3117,3124,3131,3138,3145,3152,3159,3166,3173,3180,3187,3194,3201,3208,3215,3222,3229,3236,3243,3250,3257,3264,3271,3278,3285,3292,3299,3306,3313,3320,3327,3334,3341,3348,3355,3362,3369,3376,3383,3390,3397,3404,3411,3418,3425,3432,3439,3446,3453,3460,3467,3474,3481,3488,3495,3502,3509,3516,3523,3530,3537,3544,3551,3558,3565,3572,3579,3586,3593,3600,3607,3614,3621,3628,3635,3642,3649,3656,3663,3670,3677,3684,3691,3698,3705,3712,3719,3726,3733,3740,3747,3754,3761,3768,3775,3782,3789,3796,3803,3810,3817,3824,3831,3838,3845,3852,3859,3866

lig: COM ATOMS=5647,5651,5652,5653,5654,5655,5657,5660,5661
# CV1 - distance between 12THR-OG1 and LASN-CG
d1: DISTANCE ATOMS=165,5657
# define the funnel potential region
fps: FUNNEL_PS LIGAND=lig REFERENCE=ASNase_K207_alignment.pdb ANCHOR=1953 POINTS=4.5,5.894,7.322,5.382,5.424,7.542
# calculate RMSD for constraint
# rmsd: RMSD REFERENCE=ASNase_K207_alignment.pdb TYPE=OPTIMAL

# FUNNEL ARG=fps.lp,fps.ld ZCC=2.8 ALPHA=0.55 RCYL=0.1 MINS=-0.5 MAXS=4.4 KAPPA=35100 NBINS=500 NBINZ=500 FILE=../BIAS LABEL=funnel WALKERS_MPI

# remove BIASFACTOR if you want to perform standard metadynamics

METAD ARG=d1 SIGMA=0.05 HEIGHT=0 PACE=1000000000 TEMP=310 BIASFACTOR=20 GRID_MIN=0 GRID_MAX=6 FILE=./HILLS LABEL=metad RESTART=YES

# reweighting
# as: REWEIGHT_BIAS ARG=metad.bias
as: REWEIGHT_METAD ARG=metad.bias TEMP=310
# # using the weights obtained from the metadynamics bias potentials
fps_hh: HISTOGRAM ARG=fps.lp,fps.ld STRIDE=10 GRID_MIN=-0.5,0 GRID_MAX=4.4,2.5 GRID_BIN=500,250 BANDWIDTH=0.05,0.05 LOGWEIGHTS=as
rgd1_hh: HISTOGRAM ARG=r1,d1 STRIDE=1 GRID_MIN=1,0 GRID_MAX=6,5 GRID_BIN=500,500 BANDWIDTH=0.05,0.05 LOGWEIGHTS=as
## convert to FES with minimum set to 0
fps_ff: CONVERT_TO_FES GRID=fps_hh TEMP=310 MINTOZERO
rgd1_ff: CONVERT_TO_FES GRID=rgd1_hh TEMP=310 MINTOZERO
# Print out the free energies F(s) to file once the entire trajectory is processed
DUMPGRID GRID=fps_ff FILE=ff_fps.dat
DUMPGRID GRID=rgd1_ff FILE=ff_rgd1.dat

PRINT STRIDE=1 ARG=fps.lp,fps.ld,r1,d1,metad.bias FILE=COLVAR_REWEIGHT

