RESTART
# parameter
MOLINFO STRUCTURE=./ASNase_Nter_ASN_NPT.pdb
WHOLEMOLECULES ENTITY0=800,821,833,847,866,880,899,918,928,942,949,956,970,989,999,1006,1013,1020,1032,1043,1053,1067,1089,1100,1114,1135,1149,1159,1166,1188,1204,1211,1227,1242,1256,1275,1291,1305,1315,1333,1345,1362,1381,1403,1415,1434,1444,1458,1474,1496,1503,1518,1535,1551,1567,1581,1600,1607,1618,1635,1647,1664,1678,1690,1702,1718,1742,1761,1775,1794,1804,1826,1848,1867,1881,1895,1907,1917,1929,1951,1965,1977,1984,2004,2020,2039,2053,2070,2077,2091,2103,2117,2134,2149,2164,2178,2188,2209,2229,2248,2261,2280,2294,2310,2332,2342,2354,2378,2390,2406,2422,2439,2455,2462,2472,2489,2515,2527,2538,2552,2563,2580,2591,2601,2613,2622,2634,2654,2668,2687,2708,2722,2732,2748,2764,2778,2788,2798,2810,2832,2842,2853,2863,2877,2901,2908,2924,2943,2959,2975,2992,3006,3018,3032,3048,3067,3079,3086,3110,3122,3138,3152,3174,3188,3202,3216,3230,3242,3258,3268,3282,3302,3324,3335,3351,3365,3386,3395,3407,3426,3433,3454,3473,3490,3504,3511,3533,3552,3564,3585,3602,3626,3642,3654,3664,3688,3710,3727,3741,3752,3764,3780,3792,3812,3824,3840,3851,3873,3892,3906,3921,3942,3954,3976,3992,3999,4018,4034,4055,4069,4090,4100,4114,4124,4135,4147,4168,4180,4190,4212,4222,4241,4257,4269,4279,4286,4307,4319,4326,4345,4361,4372,4382,4389,4405,4412,4426,4433,4447,4466,4487,4509,4523,4539,4559,4571,4585,4604,4614,4628,4638,4648,4670,4684,4691,4705,4715,4731,4747,4771,4782,4793,4817,4835,4847,4861,4868,4878,4892,4906,4923,4935,4945,4960,4976,4988,5000,5010,5032,5053,5060,5080,5096,5106,5117,5124,5138,5157,5173,5185,5202,5224,5234,5258,5274,5293,5312,5329,5348,5358,5377,5391,5408,5422,5444,5458,5470,5487,5504,5523,5540,5557,5576,5596,5610,5627,5651

r1: GYRATION ATOMS=5,12,19,26,33,40,47,54,61,68,75,82,89,96,103,110,117,124,131,138,145,152,159,166,173,180,187,194,201,208,215,222,229,236,243,250,257,264,271,278,285,292,299,306,313,320,327,334,341,348,355,362,369,376,383,390,397,404,411,418,425,432,439,446,453,460,467,474,481,488,495,502,509,516,523,530,537,544,551,558,565,572,579,586,593,600,607,614,621,628,635,642,649,656,663,670,677,684,691,698,705,712,719,726,733,740,747,754,761,768,775,782,789

lig: COM ATOMS=5647,5651,5652,5653,5654,5655,5657,5660,5661
# CV1 - distance between 12THR-OG1 and LASN-CG
d1: DISTANCE ATOMS=960,5657
# define the funnel potential region
fps: FUNNEL_PS LIGAND=lig REFERENCE=ASNase_Nter_alignment.pdb ANCHOR=2228 POINTS=4.97,7.538,7.363,5.827,7.223,7.658
# calculate RMSD for constraint
# rmsd: RMSD REFERENCE=ASNase_Nter_alignment.pdb TYPE=OPTIMAL

# FUNNEL ARG=fps.lp,fps.ld ZCC=2.8 ALPHA=0.55 RCYL=0.1 MINS=-0.5 MAXS=4.4 KAPPA=35100 NBINS=500 NBINZ=500 FILE=../BIAS LABEL=funnel WALKERS_MPI
# well-tempered metadynamics
METAD ARG=d1 SIGMA=0.05 HEIGHT=0 PACE=1000000000 TEMP=310 BIASFACTOR=20 GRID_MIN=0 GRID_MAX=6 FILE=./HILLS LABEL=metad RESTART=YES

# reweighting
# as: REWEIGHT_BIAS ARG=metad.bias
as: REWEIGHT_METAD ARG=metad.bias TEMP=310
# # using the weights obtained from the metadynamics bias potentials
fps_hh: HISTOGRAM ARG=fps.lp,fps.ld STRIDE=10 GRID_MIN=-0.5,0 GRID_MAX=4.4,2.5 GRID_BIN=500,250 BANDWIDTH=0.05,0.05 LOGWEIGHTS=as
rgd1_hh: HISTOGRAM ARG=r1,d1 STRIDE=1 GRID_MIN=1,0 GRID_MAX=6,5 GRID_BIN=500,500 BANDWIDTH=0.05,0.05 LOGWEIGHTS=as
## convert to FES with minimum set to 0
fps_ff: CONVERT_TO_FES GRID=fps_hh TEMP=310 MINTOZERO
rgd1_ff: CONVERT_TO_FES GRID=rgd1_hh TEMP=310 MINTOZERO
# Print out the free energies F(s) to file once the entire trajectory is processed
DUMPGRID GRID=fps_ff FILE=ff_fps.dat
DUMPGRID GRID=rgd1_ff FILE=ff_rgd1.dat

PRINT STRIDE=1 ARG=fps.lp,fps.ld,r1,d1,metad.bias FILE=COLVAR_REWEIGHT


